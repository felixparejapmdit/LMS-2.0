# ============================================================
# LMS 2.0 - Example Global Environment Configuration
# ============================================================

# The IP or domain where the application is hosted
# For local development:
# HOST_IP=localhost
# For Proxmox deployment:
HOST_IP=172.18.162.169

# URLs injected into the frontend at build time
VITE_API_URL=http://${HOST_IP}:5000/api
VITE_DIRECTUS_URL=http://${HOST_IP}:8055

# Telegram Bot (required for VIP comments)
# Example: https://your-domain.com/api/telegram/webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
