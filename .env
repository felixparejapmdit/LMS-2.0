# ============================================================
# LMS 2.0 - Global Environment Configuration
# ============================================================

# The IP or domain where the application is hosted
# For local development, this is usually localhost or 127.0.1.1
# For Proxmox deployment, it is typically 172.18.162.169 (or your VM IP)
HOST_IP=172.18.162.169

# URLs injected into the frontend at build time
VITE_API_URL=http://${HOST_IP}:5000/api
VITE_DIRECTUS_URL=http://${HOST_IP}:8055
