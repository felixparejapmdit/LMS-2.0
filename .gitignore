# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/

# Environment variables
.env.local
.env.development.local
.env.test.local
.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database (SQLite file contains real data)
directus/database/*.db
directus/database/*.db-shm
directus/database/*.db-wal
backend/src/config/database.sqlite

# Runtime-mutated app settings (backend recreates with defaults if absent)
backend/src/config/app_settings.json

# Deploy-time SQLite backups (created by scripts/deploy.sh on servers)
backups/

# Uploaded files (can be large)
backend/uploads/
directus/uploads/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Vite cache
.vite/
react-frontend/.vite/

# Directus cache & extensions
directus/.cache/
